{
    "compilerOptions": {
        "rootDir": "./src",
        "module": "nodenext",
        "target": "esnext",
        "types": ["node"],
        "declaration": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "jsx": "react-jsx",
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    }
}